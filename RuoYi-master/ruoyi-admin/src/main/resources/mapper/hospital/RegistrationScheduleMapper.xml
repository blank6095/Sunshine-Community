<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hospital.mapper.RegistrationScheduleMapper">
    <resultMap type="com.ruoyi.hospital.domain.RegistrationSchedule" id="RegistrationScheduleResult">
        <id property="scheduleId" column="schedule_id" />
        <result property="doctorId" column="doctor_id" />
        <result property="doctorName" column="doctor_name" />
        <result property="deptId" column="dept_id" />
        <result property="deptName" column="dept_name" />
        <result property="scheduleDate" column="schedule_date" />
        <result property="morningAvailable" column="morning_available" />
        <result property="afternoonAvailable" column="afternoon_available" />
        <result property="morningTotal" column="morning_total" />
        <result property="afternoonTotal" column="afternoon_total" />
        <result property="status" column="status" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectRegistrationScheduleVo">
        select rs.schedule_id, rs.doctor_id, d.doctor_name, rs.dept_id, de.dept_name, rs.schedule_date, 
               rs.morning_available, rs.afternoon_available, rs.morning_total, rs.afternoon_total, 
               rs.status, rs.create_time, rs.update_time 
        from registration_schedule rs
        left join doctor_info d on rs.doctor_id = d.doctor_id
        left join department_info de on rs.dept_id = de.dept_id
    </sql>

    <select id="selectRegistrationScheduleById" parameterType="Long" resultMap="RegistrationScheduleResult">
        <include refid="selectRegistrationScheduleVo" />
        where rs.schedule_id = #{scheduleId}
    </select>

    <select id="selectRegistrationScheduleList" parameterType="com.ruoyi.hospital.domain.RegistrationSchedule" resultMap="RegistrationScheduleResult">
        <include refid="selectRegistrationScheduleVo" />
        <where>
            <if test="doctorId != null">
                AND rs.doctor_id = #{doctorId}
            </if>
            <if test="deptId != null">
                AND rs.dept_id = #{deptId}
            </if>
            <if test="scheduleDate != null">
                AND rs.schedule_date = #{scheduleDate}
            </if>
            <if test="status != null and status != ''">
                AND rs.status = #{status}
            </if>
        </where>
    </select>

    <select id="selectRegistrationScheduleByDoctorId" parameterType="Long" resultMap="RegistrationScheduleResult">
        <include refid="selectRegistrationScheduleVo" />
        where rs.doctor_id = #{doctorId}
        and rs.status = '0'
        order by rs.schedule_date asc
    </select>

    <select id="selectRegistrationScheduleByDoctorAndDate" parameterType="map" resultMap="RegistrationScheduleResult">
        <include refid="selectRegistrationScheduleVo" />
        where rs.doctor_id = #{doctorId}
        and rs.schedule_date = #{scheduleDate}
    </select>

    <insert id="insertRegistrationSchedule" parameterType="com.ruoyi.hospital.domain.RegistrationSchedule" useGeneratedKeys="true" keyProperty="scheduleId">
        insert into registration_schedule
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="doctorId != null">doctor_id,</if>
            <if test="deptId != null">dept_id,</if>
            <if test="scheduleDate != null">schedule_date,</if>
            <if test="morningAvailable != null">morning_available,</if>
            <if test="afternoonAvailable != null">afternoon_available,</if>
            <if test="morningTotal != null">morning_total,</if>
            <if test="afternoonTotal != null">afternoon_total,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="doctorId != null">#{doctorId},</if>
            <if test="deptId != null">#{deptId},</if>
            <if test="scheduleDate != null">#{scheduleDate},</if>
            <if test="morningAvailable != null">#{morningAvailable},</if>
            <if test="afternoonAvailable != null">#{afternoonAvailable},</if>
            <if test="morningTotal != null">#{morningTotal},</if>
            <if test="afternoonTotal != null">#{afternoonTotal},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateRegistrationSchedule" parameterType="com.ruoyi.hospital.domain.RegistrationSchedule">
        update registration_schedule
        <set>
            <if test="doctorId != null">doctor_id = #{doctorId},</if>
            <if test="deptId != null">dept_id = #{deptId},</if>
            <if test="scheduleDate != null">schedule_date = #{scheduleDate},</if>
            <if test="morningAvailable != null">morning_available = #{morningAvailable},</if>
            <if test="afternoonAvailable != null">afternoon_available = #{afternoonAvailable},</if>
            <if test="morningTotal != null">morning_total = #{morningTotal},</if>
            <if test="afternoonTotal != null">afternoon_total = #{afternoonTotal},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </set>
        where schedule_id = #{scheduleId}
    </update>

    <update id="decreaseMorningAvailable" parameterType="Long">
        update registration_schedule
        set morning_available = morning_available - 1
        where schedule_id = #{scheduleId}
        and morning_available > 0
    </update>

    <update id="decreaseAfternoonAvailable" parameterType="Long">
        update registration_schedule
        set afternoon_available = afternoon_available - 1
        where schedule_id = #{scheduleId}
        and afternoon_available > 0
    </update>

    <delete id="deleteRegistrationScheduleById" parameterType="Long">
        delete from registration_schedule where schedule_id = #{scheduleId}
    </delete>

    <delete id="deleteRegistrationScheduleByIds" parameterType="Long[]">
        delete from registration_schedule where schedule_id in
        <foreach item="scheduleId" collection="array" open="(" separator="," close=")">
            #{scheduleId}
        </foreach>
    </delete>
</mapper>
<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hospital.mapper.PatientInfoMapper">
    <resultMap type="com.ruoyi.hospital.domain.PatientInfo" id="PatientInfoResult">
        <id property="patientId" column="patient_id" />
        <result property="patientName" column="patient_name" />
        <result property="idCard" column="id_card" />
        <result property="phone" column="phone" />
        <result property="gender" column="gender" />
        <result property="birthDate" column="birth_date" />
        <result property="address" column="address" />
        <result property="status" column="status" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectPatientInfoVo">
        select patient_id, patient_name, id_card, phone, gender, birth_date, address, status, create_time, update_time from patient_info
    </sql>

    <select id="selectPatientInfoById" parameterType="Long" resultMap="PatientInfoResult">
        <include refid="selectPatientInfoVo" />
        where patient_id = #{patientId}
    </select>

    <select id="selectPatientInfoByIdCard" parameterType="String" resultMap="PatientInfoResult">
        <include refid="selectPatientInfoVo" />
        where id_card = #{idCard}
    </select>

    <select id="selectPatientInfoList" parameterType="com.ruoyi.hospital.domain.PatientInfo" resultMap="PatientInfoResult">
        <include refid="selectPatientInfoVo" />
        <where>
            <if test="patientName != null and patientName != ''">
                AND patient_name like concat('%', #{patientName}, '%')
            </if>
            <if test="idCard != null and idCard != ''">
                AND id_card = #{idCard}
            </if>
            <if test="phone != null and phone != ''">
                AND phone = #{phone}
            </if>
            <if test="gender != null and gender != ''">
                AND gender = #{gender}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
    </select>

    <insert id="insertPatientInfo" parameterType="com.ruoyi.hospital.domain.PatientInfo" useGeneratedKeys="true" keyProperty="patientId">
        insert into patient_info
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="patientName != null and patientName != ''">patient_name,</if>
            <if test="idCard != null and idCard != ''">id_card,</if>
            <if test="phone != null and phone != ''">phone,</if>
            <if test="gender != null and gender != ''">gender,</if>
            <if test="birthDate != null">birth_date,</if>
            <if test="address != null and address != ''">address,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="patientName != null and patientName != ''">#{patientName},</if>
            <if test="idCard != null and idCard != ''">#{idCard},</if>
            <if test="phone != null and phone != ''">#{phone},</if>
            <if test="gender != null and gender != ''">#{gender},</if>
            <if test="birthDate != null">#{birthDate},</if>
            <if test="address != null and address != ''">#{address},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updatePatientInfo" parameterType="com.ruoyi.hospital.domain.PatientInfo">
        update patient_info
        <set>
            <if test="patientName != null and patientName != ''">patient_name = #{patientName},</if>
            <if test="idCard != null and idCard != ''">id_card = #{idCard},</if>
            <if test="phone != null and phone != ''">phone = #{phone},</if>
            <if test="gender != null and gender != ''">gender = #{gender},</if>
            <if test="birthDate != null">birth_date = #{birthDate},</if>
            <if test="address != null and address != ''">address = #{address},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </set>
        where patient_id = #{patientId}
    </update>

    <delete id="deletePatientInfoById" parameterType="Long">
        delete from patient_info where patient_id = #{patientId}
    </delete>

    <delete id="deletePatientInfoByIds" parameterType="Long[]">
        delete from patient_info where patient_id in
        <foreach item="patientId" collection="array" open="(" separator="," close=")">
            #{patientId}
        </foreach>
    </delete>
</mapper>
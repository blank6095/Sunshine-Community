<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hospital.mapper.DepartmentInfoMapper">
    <resultMap type="com.ruoyi.hospital.domain.DepartmentInfo" id="DepartmentInfoResult">
        <id property="deptId" column="dept_id" />
        <result property="deptName" column="dept_name" />
        <result property="deptCode" column="dept_code" />
        <result property="deptDesc" column="dept_desc" />
        <result property="status" column="status" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectDepartmentInfoVo">
        select dept_id, dept_name, dept_code, dept_desc, status, create_time, update_time from department_info
    </sql>

    <select id="selectDepartmentInfoById" parameterType="Long" resultMap="DepartmentInfoResult">
        <include refid="selectDepartmentInfoVo" />
        where dept_id = #{deptId}
    </select>

    <select id="selectDepartmentInfoList" parameterType="com.ruoyi.hospital.domain.DepartmentInfo" resultMap="DepartmentInfoResult">
        <include refid="selectDepartmentInfoVo" />
        <where>
            <if test="deptName != null and deptName != ''">
                AND dept_name like concat('%', #{deptName}, '%')
            </if>
            <if test="deptCode != null and deptCode != ''">
                AND dept_code = #{deptCode}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
    </select>

    <insert id="insertDepartmentInfo" parameterType="com.ruoyi.hospital.domain.DepartmentInfo" useGeneratedKeys="true" keyProperty="deptId">
        insert into department_info
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="deptName != null and deptName != ''">dept_name,</if>
            <if test="deptCode != null and deptCode != ''">dept_code,</if>
            <if test="deptDesc != null and deptDesc != ''">dept_desc,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="deptName != null and deptName != ''">#{deptName},</if>
            <if test="deptCode != null and deptCode != ''">#{deptCode},</if>
            <if test="deptDesc != null and deptDesc != ''">#{deptDesc},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateDepartmentInfo" parameterType="com.ruoyi.hospital.domain.DepartmentInfo">
        update department_info
        <set>
            <if test="deptName != null and deptName != ''">dept_name = #{deptName},</if>
            <if test="deptCode != null and deptCode != ''">dept_code = #{deptCode},</if>
            <if test="deptDesc != null and deptDesc != ''">dept_desc = #{deptDesc},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </set>
        where dept_id = #{deptId}
    </update>

    <delete id="deleteDepartmentInfoById" parameterType="Long">
        delete from department_info where dept_id = #{deptId}
    </delete>

    <delete id="deleteDepartmentInfoByIds" parameterType="Long[]">
        delete from department_info where dept_id in
        <foreach item="deptId" collection="array" open="(" separator="," close=")">
            #{deptId}
        </foreach>
    </delete>
</mapper>
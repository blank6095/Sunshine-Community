{
  "name": "ruoyi-app",
  "version": "1.2.0",
  "description": "智慧医院挂号预约系统",
  "author": "RuoYi",
  "private": true,
  "scripts": {
    "dev:h5": "uni build --mode development --platform h5",
    "build:h5": "uni build --mode production --platform h5",
    "dev:mp-weixin": "uni build --mode development --platform mp-weixin",
    "build:mp-weixin": "uni build --mode production --platform mp-weixin",
    "dev:app": "uni build --mode development --platform app",
    "build:app": "uni build --mode production --platform app"
  },
  "dependencies": {
    "@dcloudio/uni-ui": "^1.4.19",
    "pinia": "^2.1.7",
    "vue": "^3.3.4"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.8",
    "@dcloudio/uni-automator": "^3.4.8",
    "@dcloudio/uni-cli-shared": "^3.4.8",
    "@dcloudio/uni-mp-weixin": "^3.4.8",
    "@dcloudio/uni-template-compiler": "^3.4.8",
    "@vue/compiler-sfc": "^3.3.4",
    "eslint": "^8.46.0",
    "eslint-plugin-vue": "^9.16.1",
    "sass": "^1.66.1"
  },
  "uni-app": {
    "scripts": {
      "h5": {
        "title": "智慧医院",
        "router": {
          "mode": "hash"
        },
        "env": {
          "UNI_PLATFORM": "h5"
        }
      }
    }
  }
}
<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hospital.mapper.DoctorInfoMapper">
    <resultMap type="com.ruoyi.hospital.domain.DoctorInfo" id="DoctorInfoResult">
        <id property="doctorId" column="doctor_id" />
        <result property="doctorName" column="doctor_name" />
        <result property="doctorCode" column="doctor_code" />
        <result property="deptId" column="dept_id" />
        <result property="deptName" column="dept_name" />
        <result property="title" column="title" />
        <result property="specialty" column="specialty" />
        <result property="avatar" column="avatar" />
        <result property="phone" column="phone" />
        <result property="status" column="status" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectDoctorInfoVo">
        select d.doctor_id, d.doctor_name, d.doctor_code, d.dept_id, de.dept_name, d.title, d.specialty, d.avatar, d.phone, d.status, d.create_time, d.update_time 
        from doctor_info d
        left join department_info de on d.dept_id = de.dept_id
    </sql>

    <select id="selectDoctorInfoById" parameterType="Long" resultMap="DoctorInfoResult">
        <include refid="selectDoctorInfoVo" />
        where d.doctor_id = #{doctorId}
    </select>

    <select id="selectDoctorInfoList" parameterType="com.ruoyi.hospital.domain.DoctorInfo" resultMap="DoctorInfoResult">
        <include refid="selectDoctorInfoVo" />
        <where>
            <if test="doctorName != null and doctorName != ''">
                AND d.doctor_name like concat('%', #{doctorName}, '%')
            </if>
            <if test="deptId != null">
                AND d.dept_id = #{deptId}
            </if>
            <if test="title != null and title != ''">
                AND d.title like concat('%', #{title}, '%')
            </if>
            <if test="status != null and status != ''">
                AND d.status = #{status}
            </if>
        </where>
    </select>

    <select id="selectDoctorInfoByDeptId" parameterType="Long" resultMap="DoctorInfoResult">
        <include refid="selectDoctorInfoVo" />
        where d.dept_id = #{deptId}
    </select>

    <insert id="insertDoctorInfo" parameterType="com.ruoyi.hospital.domain.DoctorInfo" useGeneratedKeys="true" keyProperty="doctorId">
        insert into doctor_info
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="doctorName != null and doctorName != ''">doctor_name,</if>
            <if test="doctorCode != null and doctorCode != ''">doctor_code,</if>
            <if test="deptId != null">dept_id,</if>
            <if test="title != null and title != ''">title,</if>
            <if test="specialty != null and specialty != ''">specialty,</if>
            <if test="avatar != null and avatar != ''">avatar,</if>
            <if test="phone != null and phone != ''">phone,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="doctorName != null and doctorName != ''">#{doctorName},</if>
            <if test="doctorCode != null and doctorCode != ''">#{doctorCode},</if>
            <if test="deptId != null">#{deptId},</if>
            <if test="title != null and title != ''">#{title},</if>
            <if test="specialty != null and specialty != ''">#{specialty},</if>
            <if test="avatar != null and avatar != ''">#{avatar},</if>
            <if test="phone != null and phone != ''">#{phone},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateDoctorInfo" parameterType="com.ruoyi.hospital.domain.DoctorInfo">
        update doctor_info
        <set>
            <if test="doctorName != null and doctorName != ''">doctor_name = #{doctorName},</if>
            <if test="doctorCode != null and doctorCode != ''">doctor_code = #{doctorCode},</if>
            <if test="deptId != null">dept_id = #{deptId},</if>
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="specialty != null and specialty != ''">specialty = #{specialty},</if>
            <if test="avatar != null and avatar != ''">avatar = #{avatar},</if>
            <if test="phone != null and phone != ''">phone = #{phone},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </set>
        where doctor_id = #{doctorId}
    </update>

    <delete id="deleteDoctorInfoById" parameterType="Long">
        delete from doctor_info where doctor_id = #{doctorId}
    </delete>

    <delete id="deleteDoctorInfoByIds" parameterType="Long[]">
        delete from doctor_info where doctor_id in
        <foreach item="doctorId" collection="array" open="(" separator="," close=")">
            #{doctorId}
        </foreach>
    </delete>
</mapper>
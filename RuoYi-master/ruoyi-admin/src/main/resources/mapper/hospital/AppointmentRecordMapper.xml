<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hospital.mapper.AppointmentRecordMapper">
    <resultMap type="com.ruoyi.hospital.domain.AppointmentRecord" id="AppointmentRecordResult">
        <id property="appointmentId" column="appointment_id" />
        <result property="patientId" column="patient_id" />
        <result property="patientName" column="patient_name" />
        <result property="doctorId" column="doctor_id" />
        <result property="doctorName" column="doctor_name" />
        <result property="deptId" column="dept_id" />
        <result property="deptName" column="dept_name" />
        <result property="scheduleId" column="schedule_id" />
        <result property="appointmentDate" column="appointment_date" />
        <result property="appointmentTime" column="appointment_time" />
        <result property="registrationNo" column="registration_no" />
        <result property="status" column="status" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectAppointmentRecordVo">
        select ar.appointment_id, ar.patient_id, p.patient_name, ar.doctor_id, d.doctor_name, 
               ar.dept_id, de.dept_name, ar.schedule_id, ar.appointment_date, ar.appointment_time, 
               ar.registration_no, ar.status, ar.create_time, ar.update_time 
        from appointment_record ar
        left join patient_info p on ar.patient_id = p.patient_id
        left join doctor_info d on ar.doctor_id = d.doctor_id
        left join department_info de on ar.dept_id = de.dept_id
    </sql>

    <select id="selectAppointmentRecordById" parameterType="Long" resultMap="AppointmentRecordResult">
        <include refid="selectAppointmentRecordVo" />
        where ar.appointment_id = #{appointmentId}
    </select>

    <select id="selectAppointmentRecordList" parameterType="com.ruoyi.hospital.domain.AppointmentRecord" resultMap="AppointmentRecordResult">
        <include refid="selectAppointmentRecordVo" />
        <where>
            <if test="patientId != null">
                AND ar.patient_id = #{patientId}
            </if>
            <if test="doctorId != null">
                AND ar.doctor_id = #{doctorId}
            </if>
            <if test="deptId != null">
                AND ar.dept_id = #{deptId}
            </if>
            <if test="appointmentDate != null">
                AND ar.appointment_date = #{appointmentDate}
            </if>
            <if test="status != null and status != ''">
                AND ar.status = #{status}
            </if>
        </where>
    </select>

    <select id="selectAppointmentRecordByPatientId" parameterType="Long" resultMap="AppointmentRecordResult">
        <include refid="selectAppointmentRecordVo" />
        where ar.patient_id = #{patientId}
        order by ar.create_time desc
    </select>

    <select id="selectAppointmentRecordByDoctorId" parameterType="Long" resultMap="AppointmentRecordResult">
        <include refid="selectAppointmentRecordVo" />
        where ar.doctor_id = #{doctorId}
        order by ar.create_time desc
    </select>

    <insert id="insertAppointmentRecord" parameterType="com.ruoyi.hospital.domain.AppointmentRecord" useGeneratedKeys="true" keyProperty="appointmentId">
        insert into appointment_record
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="patientId != null">patient_id,</if>
            <if test="doctorId != null">doctor_id,</if>
            <if test="deptId != null">dept_id,</if>
            <if test="scheduleId != null">schedule_id,</if>
            <if test="appointmentDate != null">appointment_date,</if>
            <if test="appointmentTime != null">appointment_time,</if>
            <if test="registrationNo != null and registrationNo != ''">registration_no,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="patientId != null">#{patientId},</if>
            <if test="doctorId != null">#{doctorId},</if>
            <if test="deptId != null">#{deptId},</if>
            <if test="scheduleId != null">#{scheduleId},</if>
            <if test="appointmentDate != null">#{appointmentDate},</if>
            <if test="appointmentTime != null">#{appointmentTime},</if>
            <if test="registrationNo != null and registrationNo != ''">#{registrationNo},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateAppointmentRecord" parameterType="com.ruoyi.hospital.domain.AppointmentRecord">
        update appointment_record
        <set>
            <if test="patientId != null">patient_id = #{patientId},</if>
            <if test="doctorId != null">doctor_id = #{doctorId},</if>
            <if test="deptId != null">dept_id = #{deptId},</if>
            <if test="scheduleId != null">schedule_id = #{scheduleId},</if>
            <if test="appointmentDate != null">appointment_date = #{appointmentDate},</if>
            <if test="appointmentTime != null">appointment_time = #{appointmentTime},</if>
            <if test="registrationNo != null and registrationNo != ''">registration_no = #{registrationNo},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </set>
        where appointment_id = #{appointmentId}
    </update>

    <delete id="deleteAppointmentRecordById" parameterType="Long">
        delete from appointment_record where appointment_id = #{appointmentId}
    </delete>

    <delete id="deleteAppointmentRecordByIds" parameterType="Long[]">
        delete from appointment_record where appointment_id in
        <foreach item="appointmentId" collection="array" open="(" separator="," close=")">
            #{appointmentId}
        </foreach>
    </delete>
</mapper>